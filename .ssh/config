Host *
    ControlMaster auto
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlPersist 30m
    Compression yes
    ServerAliveInterval 15
    ServerAliveCountMax 6
    Ciphers chacha20-poly1305@openssh.com
    TCPKeepAlive yes
    ConnectTimeout 10
    IPQoS lowdelay throughput
    LogLevel ERROR
    RekeyLimit 256M 1h
